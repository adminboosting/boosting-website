# ============================================================================
# RankForge — environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` for local dev (or set these in the Vercel
# dashboard for production). NEVER commit a filled-in .env* file — only this
# example template is tracked. Every variable below has a safe dummy value so
# the app builds and runs in a degraded/free mode with nothing real configured.
#
# Scope legend:  [client] = safe to expose in the browser bundle (RLS-protected)
#                [server] = SECRET, server-only, must never reach the client
# ============================================================================

# --- Site -------------------------------------------------------------------
# [client] Canonical origin. Use http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---------------------------------------------------------------
# [client] Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# [client] Anon/public key (protected by Row Level Security).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# [server] Service-role key. Admin ops, webhooks, cron. NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# [server/dev] Direct Postgres connection string for migrations/scripts.
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- Credential vault (piloted orders) --------------------------------------
# [server] 32 raw bytes, base64-encoded. Generate with: pnpm generate:key
# Leave as the dummy value only for builds that never touch real credentials.
CREDENTIAL_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# --- AI (OFF by default — free MVP) -----------------------------------------
# [server] Anthropic key. Leave UNSET for the free MVP; all AI features stay
# dormant with deterministic fallbacks when this is absent.
ANTHROPIC_API_KEY=
# [server] Global AI kill switch. Default false. Even when "true", AI no-ops
# gracefully if ANTHROPIC_API_KEY is unset.
AI_FEATURES_ENABLED=false

# --- Email (Resend) ---------------------------------------------------------
# [server] Resend API key. Emails are skipped (logged only) when unset.
RESEND_API_KEY=
# [server] From address. Until a domain is verified in Resend, use the shared
# onboarding sender.
EMAIL_FROM=RankedFrogs <onboarding@resend.dev>

# --- Payments ---------------------------------------------------------------
# [server] CSV allowlist of enabled providers. Only listed providers are shown.
# Options: nowpayments, stripe_test, manual
PAYMENTS_PROVIDERS=manual
# [server] NOWPayments (crypto, primary). Uses sandbox base URL when SANDBOX=true.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=true
# [server] Stripe — TEST MODE ONLY (sk_test_...). Never a live key.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# [client] Stripe test publishable key (pk_test_...).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Monitoring (Sentry — optional, free tier) ------------------------------
# [client] DSN. When unset, Sentry is fully inert (no init, no network).
NEXT_PUBLIC_SENTRY_DSN=
# [server] Source-map upload during CI builds only. Leave unset for free MVP.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Analytics / Support widget (optional) ----------------------------------
# [client] Crisp support widget. Renders only when set.
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# --- Admin bootstrap --------------------------------------------------------
# [server] The first user who registers with this email is promoted to admin.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com

# --- Cron -------------------------------------------------------------------
# [server] Bearer token required by /api/cron/*. Set the same value in the
# Vercel Cron request header. Generate any long random string.
CRON_SECRET=change-me-to-a-long-random-string
